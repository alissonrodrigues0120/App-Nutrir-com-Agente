<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:id="@+id/consumo_crianca_sixmonth"
android:layout_height="match_parent"
android:background="@color/gray"
android:orientation="vertical"
    tools:context=".ui.avaliacao.FormsFragment_sixmonth">

<com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="@color/blue_toolbar"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:navigationIcon="@drawable/ic_arrow_back"
    app:title="Consumo Alimentar"
    app:titleTextColor="@android:color/white"/>

<ScrollView
    android:layout_width="0dp"
    android:layout_height="0dp"
    app:layout_constraintTop_toBottomOf="@id/toolbar"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CRIANÇAS MENORES DE 6 MESES"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Primeira pergunta -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A criança ontem tomou leite do peito?"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup
                    android:id="@+id/rg_leite_peito"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <RadioButton
                        android:id="@+id/rb_leite_peito_sim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sim"
                        android:layout_marginEnd="24dp"/>

                    <RadioButton
                        android:id="@+id/rb_leite_peito_nao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Não"
                        android:layout_marginEnd="24dp"/>

                    <RadioButton
                        android:id="@+id/rb_leite_peito_nao_sabe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Não Sabe"/>
                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/blue_toolbar"
                    android:layout_marginBottom="16dp"/>

                <!-- Título da seção de consumo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ontem a criança consumiu:"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:background="#E3F6F5"
                    android:padding="8dp"/>

                <!-- Mingau -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mingau"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_mingau"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_mingau_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_mingau_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_mingau_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- Água/chá -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Água/chá"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_agua_cha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_agua_cha_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_agua_cha_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_agua_cha_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- Leite de vaca -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Leite de vaca"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_leite_vaca"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_leite_vaca_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_leite_vaca_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_leite_vaca_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- Fórmula infantil -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Fórmula infantil"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_formula_infantil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_formula_infantil_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_formula_infantil_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_formula_infantil_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- Suco de fruta -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Suco de fruta"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_suco_fruta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_suco_fruta_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_suco_fruta_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_suco_fruta_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- Fruta -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Fruta"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_fruta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_fruta_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_fruta_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_fruta_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- Comida de sal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Comida de sal (de panela, papa ou sopa)"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_comida_sal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_comida_sal_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_comida_sal_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_comida_sal_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- Outros alimentos/bebidas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_item_consumo">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Outros alimentos/bebidas"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/rg_outros_alimentos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_outros_alimentos_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_outros_alimentos_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_outros_alimentos_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>

<com.google.android.material.floatingactionbutton.FloatingActionButton
    android:id="@+id/fab_confirm"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:src="@drawable/outline_arrow_forward_24"
    app:tint="@color/white"
    android:layout_margin="24dp"
    app:backgroundTint="@color/blue_toolbar"
    android:contentDescription="Confirmar"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>