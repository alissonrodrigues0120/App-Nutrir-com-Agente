<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/gray">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_eval"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue_toolbar"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@android:color/white"
        app:title="Nova Avaliação"
        app:titleTextColor="@android:color/white" />

    <!-- Barra de progresso -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="@color/white"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dados da criança"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_eval_step_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 de 3"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_toolbar" />

        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/eval_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:trackCornerRadius="8dp"
            app:indicatorColor="@color/pink"
            app:trackColor="#EBEBEB" />

    </LinearLayout>

    <!-- Container das etapas -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/eval_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="20dp"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ① Identificação -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_step1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Quem é a criança?"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="24dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome completo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/baseline_account_circle_24"
                        app:startIconTint="@color/blue_toolbar"
                        android:layout_marginBottom="20dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_nome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Data de nascimento"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/ic_calendar"
                        app:startIconTint="@color/blue_toolbar"
                        app:endIconMode="custom"
                        app:placeholderText="dd/mm/aaaa"
                        app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                        android:layout_marginBottom="24dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_data_nascimento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sexo"
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:id="@+id/container_sexo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_feminino"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Menina ♀"
                            android:textSize="16sp"
                            app:strokeColor="@color/blue_toolbar"
                            android:textColor="@color/blue_toolbar" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_masculino"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Menino ♂"
                            android:textSize="16sp"
                            app:strokeColor="@color/blue_toolbar"
                            android:textColor="@color/blue_toolbar" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ② Medidas -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_step2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Medidas Antropométricas"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="24dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Peso (kg)"
                        app:placeholderText="Ex: 12.5"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/ic_list"
                        app:startIconTint="@color/blue_toolbar"
                        android:layout_marginBottom="20dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_peso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Altura (cm)"
                        app:placeholderText="Ex: 85.0"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/outline_conditions_24"
                        app:startIconTint="@color/blue_toolbar"
                        android:layout_marginBottom="20dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_altura"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- IMC preview -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_imc_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#F5F8FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="IMC ESTIMADO"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#888888" />

                                <TextView
                                    android:id="@+id/tv_imc_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textSize="26sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/pink" />
                            </LinearLayout>
                            
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/outline_conditions_24"
                                app:tint="@color/pink" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ③ Tipo de aleitamento materno -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_step3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aleitamento Materno"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="8dp" />
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Selecione o tipo de aleitamento da criança:"
                        android:textSize="15sp"
                        android:textColor="#555555"
                        android:lineSpacingMultiplier="1.2"
                        android:layout_marginBottom="24dp" />

                    <!-- Opções de aleitamento -->
                    <LinearLayout
                        android:id="@+id/container_aleitamento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Navegação rodapé -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp"
        android:background="@color/white"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/eval_btn_previous"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="8dp"
            android:text="Voltar"
            android:textColor="@color/blue_toolbar"
            android:visibility="invisible" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/eval_btn_next"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:paddingHorizontal="32dp"
            android:text="Próxima"
            android:backgroundTint="@color/blue_toolbar"
            app:cornerRadius="28dp"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>
