<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/consumo_twoyears"
    android:layout_height="match_parent"
    android:background="@color/gray"
    android:orientation="vertical"
    tools:context=".ui.avaliacao.FormsFragment_twoyears">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue_toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Consumo Alimentar"
        app:titleTextColor="@android:color/white"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CRIANÇAS COM 2 ANOS OU MAIS"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp"/>

                    <!-- Pergunta 1: Costume de realizar refeições -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Você tem costume de realizar as refeições assistindo à TV, mexendo no computador e/ou celular?"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <RadioGroup
                        android:id="@+id/rg_costume_refeicoes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="24dp">

                        <RadioButton
                            android:id="@+id/rb_costume_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim"
                            android:layout_marginEnd="24dp"/>

                        <RadioButton
                            android:id="@+id/rb_costume_nao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginEnd="24dp"/>

                        <RadioButton
                            android:id="@+id/rb_costume_nao_sabe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não Sabe"/>
                    </RadioGroup>

                    <!-- Pergunta 2: Quais refeições faz ao longo do dia -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quais refeições você faz ao longo do dia?"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="24dp">

                        <CheckBox
                            android:id="@+id/cb_cafe_manha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Café da manhã"
                            android:layout_marginBottom="8dp"/>

                        <CheckBox
                            android:id="@+id/cb_lanche_manha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lanche da manhã"
                            android:layout_marginBottom="8dp"/>

                        <CheckBox
                            android:id="@+id/cb_almoco"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Almoço"
                            android:layout_marginBottom="8dp"/>

                        <CheckBox
                            android:id="@+id/cb_lanche_tarde"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lanche da tarde"
                            android:layout_marginBottom="8dp"/>

                        <CheckBox
                            android:id="@+id/cb_jantar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jantar"
                            android:layout_marginBottom="8dp"/>

                        <CheckBox
                            android:id="@+id/cb_ceia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ceia"/>
                    </LinearLayout>

                    <!-- Título da seção de consumo -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ontem, você consumiu:"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"
                        android:background="#E3F6F5"
                        android:padding="8dp"/>

                    <!-- Item 1: Feijão -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_item_consumo">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Feijão"
                            android:textColor="@color/black"
                            android:textSize="15sp"/>

                        <RadioGroup
                            android:id="@+id/rg_feijao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rb_feijao_sim"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sim"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_feijao_nao"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_feijao_nao_sabe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não Sabe"/>
                        </RadioGroup>
                    </LinearLayout>

                    <!-- Item 2: Frutas frescas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_item_consumo">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Frutas frescas (não considerar suco de frutas)"
                            android:textColor="@color/black"
                            android:textSize="15sp"/>

                        <RadioGroup
                            android:id="@+id/rg_frutas_frescas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rb_frutas_frescas_sim"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sim"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_frutas_frescas_nao"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_frutas_frescas_nao_sabe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não Sabe"/>
                        </RadioGroup>
                    </LinearLayout>

                    <!-- Item 3: Verduras e/ou legumes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_item_consumo">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Verduras e/ou legumes (não considerar batata, mandioca, aipim, macaxeira, cará e inhame)"
                            android:textColor="@color/black"
                            android:textSize="14sp"/>

                        <RadioGroup
                            android:id="@+id/rg_verduras_legumes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rb_verduras_legumes_sim"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sim"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_verduras_legumes_nao"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_verduras_legumes_nao_sabe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não Sabe"/>
                        </RadioGroup>
                    </LinearLayout>

                    <!-- Item 4: Hambúrguer e/ou embutidos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_item_consumo">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hambúrguer e/ou embutidos (presunto, mortadela, salame, linguiça, salsicha)"
                            android:textColor="@color/black"
                            android:textSize="14sp"/>

                        <RadioGroup
                            android:id="@+id/rg_hamburguer_embutidos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rb_hamburguer_embutidos_sim"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sim"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_hamburguer_embutidos_nao"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_hamburguer_embutidos_nao_sabe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não Sabe"/>
                        </RadioGroup>
                    </LinearLayout>

                    <!-- Item 5: Bebidas adoçadas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_item_consumo">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bebidas adoçadas (refrigerante, suco de caixinha, suco em pó, água de coco de caixinha, xaropes de guaraná/groselha, suco de fruta com adição de açúcar)"
                            android:textColor="@color/black"
                            android:textSize="13sp"/>

                        <RadioGroup
                            android:id="@+id/rg_bebidas_adocadas_2anos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rb_bebidas_adocadas_2anos_sim"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sim"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_bebidas_adocadas_2anos_nao"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_bebidas_adocadas_2anos_nao_sabe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não Sabe"/>
                        </RadioGroup>
                    </LinearLayout>

                    <!-- Item 6: Macarrão instantâneo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_item_consumo">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Macarrão instantâneo, salgadinhos de pacote ou biscoitos salgados"
                            android:textColor="@color/black"
                            android:textSize="14sp"/>

                        <RadioGroup
                            android:id="@+id/rg_macarrao_salgados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rb_macarrao_salgados_sim"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sim"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_macarrao_salgados_nao"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_macarrao_salgados_nao_sabe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não Sabe"/>
                        </RadioGroup>
                    </LinearLayout>

                    <!-- Item 7: Biscoito recheado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_item_consumo">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Biscoito recheado, doces ou guloseimas (balas, pirulitos, chiclete, caramelo, gelatina)"
                            android:textColor="@color/black"
                            android:textSize="14sp"/>

                        <RadioGroup
                            android:id="@+id/rg_biscoito_doces"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/rb_biscoito_doces_sim"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sim"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_biscoito_doces_nao"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não"
                                android:layout_marginEnd="16dp"/>

                            <RadioButton
                                android:id="@+id/rb_biscoito_doces_nao_sabe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Não Sabe"/>
                        </RadioGroup>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_confirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/outline_arrow_forward_24"
        app:tint="@color/white"
        android:layout_margin="24dp"
        app:backgroundTint="@color/blue_toolbar"
        android:contentDescription="Confirmar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>