<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_crianca"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="2dp"
    app:cardBackgroundColor="@color/gray"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:contentPadding="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Botão de Delete (canto superior direito) -->
        <ImageButton
            android:id="@+id/btn_apagar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/apagar"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/delete"
            app:tint="@color/red"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:padding="8dp" />

        <!-- Container de Dados -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/btn_apagar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Nome -->
            <TextView
                android:id="@+id/itemNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nome"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Maria Silva" />

            <!-- Status com Badge visual -->
            <TextView
                android:id="@+id/itemStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/resultados_status_description_adequate"
                android:textStyle="bold"
                android:textColor="@color/green"
                android:textSize="14sp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                tools:text="Adequado" />

            <!-- Grid de Informações (2 colunas) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="2"
                android:rowCount="3"
                android:alignmentMode="alignBounds">

                <!-- IMC -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_columnWeight="1"
                    android:text="@string/imc_value"
                    android:textSize="12sp"
                    android:textColor="@color/gray_dark" />
                <TextView
                    android:id="@+id/itemImc"
                    android:layout_width="0dp"
                    android:visibility="gone"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    tools:text="18.5 kg/m²" />

                <!-- Z-Score -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/zscore_value"
                    android:visibility="gone"
                    android:textSize="12sp"
                    android:textColor="@color/gray_dark" />
                <TextView
                    android:id="@+id/itemZscore"
                    android:layout_width="0dp"
                    android:visibility="gone"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    tools:text="+0.5" />

                <!-- Peso -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/peso"
                    android:textSize="12sp"
                    android:textColor="@color/gray_dark" />
                <TextView
                    android:id="@+id/itemPeso"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    tools:text="25.3 kg" />

                <!-- Altura -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/altura"
                    android:textSize="12sp"
                    android:textColor="@color/gray_dark" />
                <TextView
                    android:id="@+id/itemAltura"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    tools:text="120 cm" />

                <!-- Idade (ocupa as 2 colunas) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnSpan="2"
                    android:layout_columnWeight="1"
                    android:layout_marginTop="4dp"
                    android:text="@string/idade"
                    android:textSize="12sp"
                    android:textColor="@color/gray_dark" />
                <TextView
                    android:id="@+id/itemIdade"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnSpan="2"
                    android:layout_columnWeight="1"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    tools:text="7 anos e 3 meses" />

            </GridLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>