<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/new_evaluation"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/gray"
    android:orientation="vertical"
    tools:context=".ui.avaliacao.NewEvaluationFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue_toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Avaliação"
        app:titleTextColor="@android:color/white"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/text_informacoes_crianca"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Informações da Criança"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome da Criança"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/baseline_account_circle_24"
                        app:startIconTint="@color/blue_toolbar"
                        android:layout_marginBottom="20dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_nome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Data de nascimento"
                        app:placeholderText="DD/MM/AAAA"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/ic_calendar"
                        app:startIconTint="@color/blue_toolbar"
                        app:endIconMode="custom"
                        app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                        android:layout_marginBottom="20dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_data_nascimento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Altura (cm)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/outline_conditions_24"
                        app:startIconTint="@color/blue_toolbar"
                        android:layout_marginBottom="20dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_altura"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Peso (kg)"
                        app:placeholderText="Ex: 3.2"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/ic_list"
                        app:startIconTint="@color/blue_toolbar"
                        android:layout_marginBottom="24dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_peso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sexo"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:layout_marginBottom="12dp"
                        android:textStyle="bold"/>

                    <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">
                        <RadioButton
                            android:id="@+id/rb_feminino"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Feminino"
                            android:checked="true"
                            android:buttonTint="@color/blue_toolbar"
                            android:layout_marginEnd="32dp"/>
                        <RadioButton
                            android:id="@+id/rb_masculino"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_toolbar"
                            android:text="Masculino"/>
                    </RadioGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipos de aleitamentos"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="24dp">
                        
                        <RadioButton
                            android:id="@+id/rb_ame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_toolbar"
                            android:layout_marginBottom="8dp"
                            android:text="Aleitamento materno exclusivo" />

                        <RadioButton
                            android:id="@+id/rb_amp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_toolbar"
                            android:layout_marginBottom="8dp"
                            android:text="Aleitamento materno predominante"/>

                        <RadioButton
                            android:id="@+id/rb_am"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_toolbar"
                            android:layout_marginBottom="8dp"
                            android:text="Aleitamento materno"/>

                        <RadioButton
                            android:id="@+id/rb_amc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_toolbar"
                            android:layout_marginBottom="8dp"
                            android:text="Aleitamento materno complementado"/>

                        <RadioButton
                            android:id="@+id/rb_ammp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_toolbar"
                            android:layout_marginBottom="8dp"
                            android:text="Aleitamento materno misto ou parcial"/>

                        <RadioButton
                            android:id="@+id/rb_aa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_toolbar"
                            android:text="Aleitamento artificial"/>
                    </RadioGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dicionário de Aleitamentos"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:textAllCaps="true"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:paddingBottom="12dp"
                        android:paddingEnd="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- ALEITAMENTO MATERNO EXCLUSIVO -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="260dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                app:cardBackgroundColor="#F5F8FF"
                                app:cardCornerRadius="16dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#D0DFFF"
                                app:cardElevation="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Exclusivo"
                                        android:textStyle="bold"
                                        android:textSize="16sp"
                                        android:textColor="@color/blue_toolbar"
                                        android:paddingBottom="12dp"/>
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:background="#D0DFFF"
                                        android:layout_marginBottom="12dp"/>
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Somente leite materno (direto ou ordenhado) ou de outra fonte, sem outros líquidos ou sólidos (exceto vitaminas/remédios)."
                                        android:textColor="#555555"
                                        android:lineSpacingMultiplier="1.2"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- ALEITAMENTO MATERNO PREDOMINANTE -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="260dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                app:cardBackgroundColor="#F5F8FF"
                                app:cardCornerRadius="16dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#D0DFFF"
                                app:cardElevation="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Predominante"
                                        android:textStyle="bold"
                                        android:textSize="16sp"
                                        android:textColor="@color/blue_toolbar"
                                        android:paddingBottom="12dp"/>
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:background="#D0DFFF"
                                        android:layout_marginBottom="12dp"/>
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Leite materno + água ou bebidas à base de água (chás, infusões), sucos e fluidos rituais."
                                        android:textColor="#555555"
                                        android:lineSpacingMultiplier="1.2"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- ALEITAMENTO MATERNO -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="260dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                app:cardBackgroundColor="#F5F8FF"
                                app:cardCornerRadius="16dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#D0DFFF"
                                app:cardElevation="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Aleitamento Materno"
                                        android:textStyle="bold"
                                        android:textSize="16sp"
                                        android:textColor="@color/blue_toolbar"
                                        android:paddingBottom="12dp"/>
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:background="#D0DFFF"
                                        android:layout_marginBottom="12dp"/>
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Leite materno (direto da mama ou ordenhado), independentemente de receber ou não outros alimentos."
                                        android:textColor="#555555"
                                        android:lineSpacingMultiplier="1.2"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- ALEITAMENTO MATERNO COMPLEMENTADO -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="260dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                app:cardBackgroundColor="#F5F8FF"
                                app:cardCornerRadius="16dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#D0DFFF"
                                app:cardElevation="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Complementado"
                                        android:textStyle="bold"
                                        android:textSize="16sp"
                                        android:textColor="@color/blue_toolbar"
                                        android:paddingBottom="12dp"/>
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:background="#D0DFFF"
                                        android:layout_marginBottom="12dp"/>
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Leite materno + qualquer alimento sólido ou semissólido com a finalidade de complementar, não substituir."
                                        android:textColor="#555555"
                                        android:lineSpacingMultiplier="1.2"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- ALEITAMENTO MATERNO MISTO OU PARCIAL -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="260dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                app:cardBackgroundColor="#F5F8FF"
                                app:cardCornerRadius="16dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#D0DFFF"
                                app:cardElevation="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Misto ou Parcial"
                                        android:textStyle="bold"
                                        android:textSize="16sp"
                                        android:textColor="@color/blue_toolbar"
                                        android:paddingBottom="12dp"/>
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:background="#D0DFFF"
                                        android:layout_marginBottom="12dp"/>
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Quando a criança recebe leite materno e outros tipos de leite."
                                        android:textColor="#555555"
                                        android:lineSpacingMultiplier="1.2"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- ALEITAMENTO ARTIFICIAL -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="260dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                app:cardBackgroundColor="#F5F8FF"
                                app:cardCornerRadius="16dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#D0DFFF"
                                app:cardElevation="0dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Artificial"
                                        android:textStyle="bold"
                                        android:textSize="16sp"
                                        android:textColor="@color/blue_toolbar"
                                        android:paddingBottom="12dp"/>
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:background="#D0DFFF"
                                        android:layout_marginBottom="12dp"/>
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Qualquer forma de ingestão de leite que não seja diretamente do seio materno."
                                        android:textColor="#555555"
                                        android:lineSpacingMultiplier="1.2"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_confirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="Continuar"
        app:icon="@drawable/outline_arrow_forward_24"
        android:textColor="@color/white"
        app:iconTint="@color/white"
        app:backgroundTint="@color/blue_toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
